# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ClickUp (personal API token — https://app.clickup.com/settings/apps)
CLICKUP_TOKEN=

# Trello (https://trello.com/power-ups/admin)
TRELLO_KEY=
TRELLO_TOKEN=

# Webhook signature secret (used to validate inbound webhooks)
# Generate with: php -r "echo bin2hex(random_bytes(32));"
WEBHOOK_SECRET=

# Public base URL where this app is reachable from the internet
# (needed so we can register webhooks with ClickUp/Trello)
PUBLIC_BASE_URL=https://bqbstudio.com/ginger-sync

# Dashboard auth — bcrypt hash of the login password.
# Generate with: php -r "echo password_hash('OpenShakra!', PASSWORD_BCRYPT);"
# (Stored here as fallback; primary source is ginger_sync.settings in Supabase.)
DASHBOARD_PASSWORD_HASH=
