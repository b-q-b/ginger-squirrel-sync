# ─────────────────────────────────────────────────────────
# ginger-squirrel-sync — production .env (VPS root of repo)
# Copy to .env and fill values. Never commit the real .env.
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# Option A — Supabase-managed Postgres (recommended for v1):
#   Get this from Supabase → Project Settings → Database → Connection string (Direct Connection)
#   Format: Host=db.<ref>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<pw>;SSL Mode=Require;Trust Server Certificate=true
POSTGRES_CONNECTION=

# Optional: Supabase REST (only if any code path still calls PostgREST; not needed for EF Core)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ── ClickUp + Trello ─────────────────────────────────────
CLICKUP_TOKEN=
TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_SECRET=

# ── AI services for the Meetings module ──────────────────
ASSEMBLYAI_API_KEY=
OPENROUTER_API_KEY=

# ── App secrets ──────────────────────────────────────────
# Shared secret used as the cron auth key (?key=...) and for webhook validation.
WEBHOOK_SECRET=

# JWT signing secret for the login cookie. Minimum 32 characters.
# Generate with:  openssl rand -hex 32
GINGERSYNC_Auth__JwtSecret=
